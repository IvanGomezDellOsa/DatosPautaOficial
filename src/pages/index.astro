---
import Layout from "../layouts/Layout.astro";
import "@fontsource-variable/space-grotesk";
import DataTable from "../components/DataTable";
import Rankings from "../components/Rankings";
import Generador from "../components/Generador";
---

<Layout
    title="Datos Pauta Oficial"
    description="Todos los datos públicos de pauta oficial de la Argentina, en un solo lugar."
>
    {/* patrón hatched para huecos de cobertura */}
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
        <defs>
            <pattern
                id="gap-pattern"
                x="0"
                y="0"
                width="6"
                height="6"
                patternUnits="userSpaceOnUse"
                patternTransform="rotate(45)"
            >
                <line
                    x1="0"
                    y1="0"
                    x2="0"
                    y2="6"
                    stroke="#27272a"
                    stroke-width="0.8"></line>
            </pattern>
        </defs>
    </svg>

    {/* ═══════ NAV ═══════ */}
    <nav class="site-nav" id="site-nav" aria-label="Navegación">
        <div class="container-wide nav-inner">
            <div class="nav-brand-mobile">
                <span class="wordmark">Datos Pauta Oficial</span>
                <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Abrir menú" aria-expanded="false">
                    <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
            </div>
            <div class="nav-links" id="navLinks">
                <a href="#inicio" class="nav-link" data-nav="inicio">Inicio</a>
                <a href="#datos" class="nav-link" data-nav="datos">Datos</a>
                <a href="#cobertura" class="nav-link" data-nav="cobertura">Cobertura</a>
                <a href="#cuanto-recibio" class="nav-link" data-nav="cuanto-recibio">Cuánto recibió</a>
                <a href="#receptores" class="nav-link" data-nav="receptores">Ranking</a>
                <a href="#acerca" class="nav-link" data-nav="acerca">Acerca de</a>
            </div>
        </div>
    </nav>

    {/* ═══════ HERO ═══════ */}
    <section class="hero" id="inicio">
        <div class="container-wide">
            <div class="hero-grid">
                <div class="hero-text">
                    <h1 class="hero-claim">
                        <span class="line">Datos pauta oficial</span>
                        <span class="line">Argentina.</span>
                        <span class="line"><em>En un solo lugar.</em></span>
                    </h1>

                    <div class="hero-stats">
                        <div class="stat">
                            <span class="number" data-count="504707">0</span>
                            <span class="label">pautas asignadas</span>
                        </div>
                        <div class="stat">
                            <span class="number" data-count="12260">0</span>
                            <span class="label">medios</span>
                        </div>
                        <div class="stat">
                            <span class="number" data-count="7178">0</span>
                            <span class="label"
                                >proveedores que recibieron dinero</span
                            >
                        </div>
                        <div class="stat">
                            <span class="number" data-count="4">0</span>
                            <span class="label">jurisdicciones</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <button
            class="scroll-hint"
            id="scrollHint"
            aria-label="Bajar a los datos"
            type="button"
        >
            <span>Explorar datos</span>
            <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
        </button>
    </section>

    {/* ═══════ TABLA ═══════ */}
    <section class="table-section reveal" id="datos">
        <div class="container-wide">
            <div class="section-head">
                <h2>Todos los datos</h2>
                <p>504.707 órdenes — con sistema de filtros.</p>
            </div>
            <DataTable client:only="react" />
        </div>
    </section>

    {/* ═══════ COBERTURA DE LA BASE ═══════ */}
    <section class="coverage-section reveal" id="cobertura">
        <div class="container-wide">
            <div class="section-head">
                <h2>Cobertura de nuestra base de datos</h2>
            </div>

            <div class="coverage-grid">
                {/* ── NACIONAL ── */}
                <div class="cov-card">
                    <div class="cov-juris-name">Nacional</div>
                    <div class="cov-period">2009 — 2022</div>
                    <div class="cov-bar-wrap">
                        <div
                            class="cov-bar"
                            title="Nacional: 2009–2022 (escala 2003–2027)"
                        >
                            <div class="cov-seg cov-empty" style="flex:6"></div>
                            <div class="cov-seg cov-filled" style="flex:13">
                            </div>
                            <div class="cov-seg cov-empty" style="flex:5"></div>
                        </div>
                        <div class="cov-axis">
                            <span style="left:0%">2003</span>
                            <span style="left:29%">2010</span>
                            <span style="left:50%">2015</span>
                            <span style="left:71%">2020</span>
                            <span style="left:100%">2027</span>
                        </div>
                    </div>
                    <div class="cov-note">
                        Desde 2024, presupuesto publicitario de la
                        Administración Central bloqueado por decreto.
                        <a
                            href="https://www.boletinoficial.gob.ar/detalleAviso/primera/301352/20231227"
                            target="_blank"
                            rel="noopener"
                            class="cov-note-link">Boletín Oficial ↗</a
                        >
                    </div>
                </div>

                {/* ── CABA ── */}
                <div class="cov-card">
                    <div class="cov-juris-name">CABA</div>
                    <div class="cov-period">2003 — 2024</div>
                    <div class="cov-bar-wrap">
                        <div
                            class="cov-bar"
                            title="CABA: 2003–2024 (escala 2003–2027)"
                        >
                            <div class="cov-seg cov-filled" style="flex:21">
                            </div>
                            <div class="cov-seg cov-empty" style="flex:3"></div>
                        </div>
                        <div class="cov-axis">
                            <span style="left:0%">2003</span>
                            <span style="left:29%">2010</span>
                            <span style="left:50%">2015</span>
                            <span style="left:71%">2020</span>
                            <span style="left:100%">2027</span>
                        </div>
                    </div>
                </div>

                {/* ── PBA ── */}
                <div class="cov-card">
                    <div class="cov-juris-name">
                        PBA
                        <span class="cov-excl-badge">exclusivo</span>
                    </div>
                    <div class="cov-period">2020 — 2025</div>
                    <div class="cov-bar-wrap">
                        <div
                            class="cov-bar"
                            title="PBA: 2020–2024 exclusivo (cyan) + 2025 fuente oficial (escala 2003–2027)"
                        >
                            <div class="cov-seg cov-empty" style="flex:17">
                            </div>
                            <div
                                class="cov-seg cov-accent"
                                style="flex:4"
                                title="Exclusivo: datos armados resolución por resolución"
                            >
                            </div>
                            <div
                                class="cov-seg cov-filled-light"
                                style="flex:1"
                                title="2025: fuente oficial pública"
                            >
                            </div>
                            <div class="cov-seg cov-empty" style="flex:2"></div>
                        </div>
                        <div class="cov-axis">
                            <span style="left:0%">2003</span>
                            <span style="left:29%">2010</span>
                            <span style="left:50%">2015</span>
                            <span style="left:71%">2020</span>
                            <span style="left:100%">2027</span>
                        </div>
                    </div>
                    <div class="cov-note cov-note-excl">
                        2020–2024: unificado resolución por resolución
                    </div>
                </div>

                {/* ── SANTA FE ── */}
                <div class="cov-card">
                    <div class="cov-juris-name">Santa Fe</div>
                    <div class="cov-period">2019 — 2023</div>
                    <div class="cov-bar-wrap">
                        <div
                            class="cov-bar"
                            title="Santa Fe: 2019–2023 (escala 2003–2027)"
                        >
                            <div class="cov-seg cov-empty" style="flex:16">
                            </div>
                            <div class="cov-seg cov-filled" style="flex:5">
                            </div>
                            <div class="cov-seg cov-empty" style="flex:3"></div>
                        </div>
                        <div class="cov-axis">
                            <span style="left:0%">2003</span>
                            <span style="left:29%">2010</span>
                            <span style="left:50%">2015</span>
                            <span style="left:71%">2020</span>
                            <span style="left:100%">2027</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="coverage-note-strip">
                <strong>Sobre los datos ausentes.</strong>
                Si un organismo o período no aparece, no es una decisión. Esa información
                no está accesible ni transparentada por los organismos correspondientes.
            </div>
        </div>
    </section>

    {/* ═══════ CUÁNTO RECIBIÓ ═══════ */}
    <section class="generator-section reveal" id="cuanto-recibio">
        <div class="container-wide">
            <div class="section-head">
                <h2>Cuánto recibió</h2>
                <p>
                    Buscá cualquier medio o proveedor. Compartí el dato en tus
                    redes sociales.
                </p>
            </div>

            <Generador client:only="react" />
        </div>
    </section>

    {/* ═══════ TOP RECEPTORES ═══════ */}
    <section class="rankings-section reveal" id="receptores">
        <div class="container-wide">
            <div class="section-head">
                <h2>Ranking</h2>
            </div>

            <Rankings client:only="react" />
        </div>
    </section>

    {/* ═══════ FOOTER ═══════ */}
    <footer class="site-footer" id="acerca">
        <div class="container-wide footer-topbar">
            <a
                class="brand"
                href="#"
                style="display:inline-flex; align-items:center; gap:10px;"
            >
                <svg
                    viewBox="0 0 16 10"
                    width="20"
                    height="13"
                    style="border-radius:2px"
                >
                    <rect width="16" height="3.33" y="0" fill="#74acdf"></rect>
                    <rect width="16" height="3.34" y="3.33" fill="#ffffff"
                    ></rect>
                    <rect width="16" height="3.33" y="6.67" fill="#74acdf"
                    ></rect>
                </svg>
                <span class="wordmark">Datos Pauta Oficial</span>
            </a>
            <div class="footer-links">
                <a
                    href="mailto:ivan.gdo@outlook.com?subject=Consulta%20sobre%20Datos%20Pauta%20Oficial"
                    class="footer-contact-btn">Contacto</a
                >
            </div>
        </div>

        <div class="container-wide">
            <div class="footer-about">
                <div class="footer-about-title">Acerca de los datos</div>
                <div class="footer-about-grid">
                    <div class="footer-about-item">
                        <div class="footer-about-item-label">Deflactación</div>
                        <p>
                            Todos los montos están expresados en pesos de marzo
                            2026, deflactados contra el IPC INDEC mensual.
                        </p>
                    </div>
                    <div class="footer-about-item">
                        <div class="footer-about-item-label">PBA 2020–2024</div>
                        <p>
                            Datos recopilados resolución por resolución. No
                            están disponibles en ninguna otra fuente unificada.
                        </p>
                    </div>
                    <div class="footer-about-item">
                        <div class="footer-about-item-label">
                            Aproximaciones
                        </div>
                        <p>
                            Los totales son <em>aproximaciones inferiores</em>:
                            al haber huecos de cobertura, el monto real puede
                            ser mayor.
                        </p>
                    </div>
                    <div class="footer-about-item">
                        <div class="footer-about-item-label">
                            Datos ausentes
                        </div>
                        <p>
                            Si un organismo o período no aparece, esa
                            información no está accesible ni transparentada por
                            los organismos correspondientes.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <div class="toast" id="toast"></div>

    {/* ═══════ BOTONES FLOTANTES ═══════ */}
    <div class="fs-float" id="fsFloat">
        <button
            class="back-top-btn"
            id="backTopBtn"
            aria-label="Volver al inicio"
            type="button"
            style="display:none"
        >
            <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <polyline points="18 15 12 9 6 15"></polyline>
            </svg>
            Inicio
        </button>
        <div class="fs-panel" id="fsPanel" hidden>
            <button id="fsSm" type="button">Normal</button>
            <button id="fsLg" type="button">Grande</button>
            <button id="fsXl" type="button">Muy grande</button>
        </div>
        <button
            class="fs-float-btn"
            id="fsFloatBtn"
            type="button"
            aria-expanded="false"
            aria-controls="fsPanel"
        >
            <span class="fs-ico">Aa</span>
            Tamaño de letra
        </button>
    </div>
</Layout>

<script is:inline>
    // ─────────── Count-up de cifras del hero ───────────
    (function () {
        var nums = document.querySelectorAll(".hero-stats .number[data-count]");
        var formatter = new Intl.NumberFormat("es-AR");
        function ease(p) {
            return 1 - Math.pow(1 - p, 3);
        }
        function animate(el, target, duration, delay) {
            el.textContent = formatter.format(0);
            var t0;
            function frame(t) {
                if (!t0) t0 = t;
                var elapsed = t - t0;
                if (elapsed < delay) {
                    requestAnimationFrame(frame);
                    return;
                }
                var p = Math.min(1, (elapsed - delay) / duration);
                el.textContent = formatter.format(Math.round(target * ease(p)));
                if (p < 1) requestAnimationFrame(frame);
            }
            requestAnimationFrame(frame);
        }
        function go() {
            nums.forEach(function (el, i) {
                animate(
                    el,
                    parseInt(el.dataset.count, 10),
                    2200,
                    900 + i * 150,
                );
            });
        }
        if (document.readyState === "complete") go();
        else window.addEventListener("load", go);
    })();

    // ─────────── Scroll reveal de secciones ───────────
    (function () {
        var els = document.querySelectorAll(".reveal");
        var io = new IntersectionObserver(
            function (entries) {
                entries.forEach(function (en) {
                    if (en.isIntersecting) en.target.classList.add("in-view");
                });
            },
            { threshold: 0.08 },
        );
        els.forEach(function (el) {
            io.observe(el);
        });
    })();

    // Generador y Rankings son React islands (Generador.tsx / Rankings.tsx).
    // Sus handlers de year-pills, segmented, barras y share ya no viven aquí.

    // ─────────── Control tamaño de fuente (flotante) ───────────
    (function () {
        var sizes = ["", "lg", "xl"];
        var current = localStorage.getItem("textSize") || "";
        var panel = document.getElementById("fsPanel");
        var floatBtn = document.getElementById("fsFloatBtn");
        var btnSm = document.getElementById("fsSm");
        var btnLg = document.getElementById("fsLg");
        var btnXl = document.getElementById("fsXl");
        function apply(size) {
            current = size;
            // Aplica al root (html) para escalar todas las medidas en 'rem' correctamente
            document.documentElement.style.fontSize =
                size === "lg" ? "110%" : size === "xl" ? "125%" : "";
            localStorage.setItem("textSize", size);
            [btnSm, btnLg, btnXl].forEach(function (b) {
                b && b.classList.remove("on");
            });
            if (size === "") btnSm && btnSm.classList.add("on");
            if (size === "lg") btnLg && btnLg.classList.add("on");
            if (size === "xl") btnXl && btnXl.classList.add("on");
        }
        function togglePanel() {
            var open = !panel.hidden;
            panel.hidden = open;
            floatBtn.setAttribute("aria-expanded", String(!open));
        }
        apply(current);
        floatBtn &&
            floatBtn.addEventListener("click", function (e) {
                e.stopPropagation();
                togglePanel();
            });
        btnSm &&
            btnSm.addEventListener("click", function () {
                apply("");
            });
        btnLg &&
            btnLg.addEventListener("click", function () {
                apply("lg");
            });
        btnXl &&
            btnXl.addEventListener("click", function () {
                apply("xl");
            });
        document.addEventListener("click", function (e) {
            var float = document.getElementById("fsFloat");
            if (float && !float.contains(e.target) && !panel.hidden)
                panel.hidden = true;
        });
    })();


    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Scroll hint (flotante hero) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    (function () {
        var hint = document.getElementById("scrollHint");
        if (!hint) return;
        hint.addEventListener("click", function () {
            var target = document.querySelector(".table-section");
            if (target) target.scrollIntoView({ behavior: "smooth" });
        });
        var hidden = false;
        window.addEventListener(
            "scroll",
            function () {
                var y = window.scrollY || window.pageYOffset;
                if (!hidden && y > 80) {
                    hint.classList.add("hidden");
                    hidden = true;
                } else if (hidden && y <= 80) {
                    hint.classList.remove("hidden");
                    hidden = false;
                }
            },
            { passive: true },
        );
    })();

    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Volver al inicio \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    (function () {
        var btn = document.getElementById("backTopBtn");
        if (!btn) return;
        window.addEventListener(
            "scroll",
            function () {
                var y = window.scrollY || window.pageYOffset;
                btn.style.display = y > 300 ? "" : "none";
            },
            { passive: true },
        );
        btn.addEventListener("click", function () {
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    })();

    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Nav: link activo por scroll \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    (function () {
        var links = document.querySelectorAll(".nav-link[data-nav]");
        var sections = [];
        links.forEach(function (l) {
            var el = document.getElementById(l.dataset.nav);
            if (el) sections.push({ el: el, link: l });
        });
        if (!sections.length) return;
        var navH =
            (document.getElementById("site-nav") || {}).offsetHeight || 44;
        function update() {
            var y = window.scrollY || window.pageYOffset;
            var active = sections[0];
            for (var i = 0; i < sections.length; i++) {
                if (sections[i].el.getBoundingClientRect().top <= navH + 8) {
                    active = sections[i];
                }
            }
            links.forEach(function (l) {
                l.classList.remove("active");
            });
            active.link.classList.add("active");
        }
        window.addEventListener("scroll", update, { passive: true });
        update();
    })();

    // ─────────── Mobile Menu Toggle ───────────
    (function () {
        var btn = document.getElementById("mobileMenuBtn");
        var links = document.getElementById("navLinks");
        var nav = document.getElementById("site-nav");
        if (btn && links && nav) {
            btn.addEventListener("click", function () {
                var expanded = btn.getAttribute("aria-expanded") === "true";
                btn.setAttribute("aria-expanded", !expanded);
                links.classList.toggle("open");
            });
            links.addEventListener("click", function (e) {
                if (e.target.tagName.toLowerCase() === "a") {
                    btn.setAttribute("aria-expanded", "false");
                    links.classList.remove("open");
                }
            });
            document.addEventListener("click", function (e) {
                if (!nav.contains(e.target) && links.classList.contains("open")) {
                    btn.setAttribute("aria-expanded", "false");
                    links.classList.remove("open");
                }
            });
        }
    })();

    // ─────────── Smart Sticky Header ───────────
    (function() {
        var lastScroll = 0;
        var nav = document.getElementById("site-nav");
        if (!nav) return;
        window.addEventListener("scroll", function() {
            var currentScroll = window.pageYOffset;
            if (currentScroll <= 56) {
                nav.classList.remove("scroll-up");
                nav.classList.remove("scroll-down");
                return;
            }
            if (currentScroll > lastScroll && !nav.classList.contains("scroll-down")) {
                nav.classList.remove("scroll-up");
                nav.classList.add("scroll-down");
            } else if (currentScroll < lastScroll && nav.classList.contains("scroll-down")) {
                nav.classList.remove("scroll-down");
                nav.classList.add("scroll-up");
            }
            lastScroll = currentScroll;
        }, { passive: true });
