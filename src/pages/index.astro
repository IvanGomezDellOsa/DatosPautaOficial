<script is:inline>
    // ─────────── Count-up de cifras del hero ───────────
    (function () {
        var nums = document.querySelectorAll(".hero-stats .number[data-count]");
        var formatter = new Intl.NumberFormat("es-AR");
        function ease(p) {
            return 1 - Math.pow(1 - p, 3);
        }
        function animate(el, target, duration, delay) {
            el.textContent = formatter.format(0);
            var t0;
            function frame(t) {
                if (!t0) t0 = t;
                var elapsed = t - t0;
                if (elapsed < delay) {
                    requestAnimationFrame(frame);
                    return;
                }
                var p = Math.min(1, (elapsed - delay) / duration);
                el.textContent = formatter.format(Math.round(target * ease(p)));
                if (p < 1) requestAnimationFrame(frame);
            }
            requestAnimationFrame(frame);
        }
        function go() {
            nums.forEach(function (el, i) {
                animate(
                    el,
                    parseInt(el.dataset.count, 10),
                    2200,
                    900 + i * 150,
                );
            });
        }
        if (document.readyState === "complete") go();
        else window.addEventListener("load", go);
    })();

    // ─────────── Scroll reveal de secciones ───────────
    (function () {
        var els = document.querySelectorAll(".reveal");
        var io = new IntersectionObserver(
            function (entries) {
                entries.forEach(function (en) {
                    if (en.isIntersecting) en.target.classList.add("in-view");
                });
            },
            { threshold: 0.08 },
        );
        els.forEach(function (el) {
            io.observe(el);
        });
    })();

    // ─────────── Year pills del generador + animación de monto ───────────
    (function () {
        var pills = document.querySelectorAll(".year-pill");
        var monto = document.getElementById("genMonto");
        var eyebrow = document.getElementById("genEyebrow");

        pills.forEach(function (pill) {
            pill.addEventListener("click", function () {
                pills.forEach(function (p) {
                    p.classList.remove("on");
                });
                pill.classList.add("on");

                // Animación fade-out + slide 6px → fade-in sobre el monto
                if (monto) {
                    monto.style.transition = "none";
                    monto.style.opacity = "0";
                    monto.style.transform = "translateY(6px)";
                    requestAnimationFrame(function () {
                        requestAnimationFrame(function () {
                            monto.style.transition =
                                "opacity 300ms ease, transform 300ms ease";
                            monto.style.opacity = "";
                            monto.style.transform = "";
                        });
                    });
                }
            });
        });

        // Toggle segmented Proveedor / Medio en el generador
        var genSeg = document.querySelector(".gen-search-row .segmented");
        if (genSeg) {
            var segBtns = genSeg.querySelectorAll("button");
            segBtns.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    segBtns.forEach(function (b) {
                        b.classList.remove("on");
                    });
                    btn.classList.add("on");
                    if (eyebrow) eyebrow.textContent = btn.textContent.trim();
                });
            });
        }
    })();

    // ─────────── Barras de ranking al entrar en viewport ───────────
    (function () {
        var bars = document.querySelectorAll(".ranking-row .bar > span");
        var seen = new WeakSet();
        var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (en) {
                if (en.isIntersecting && !seen.has(en.target)) {
                    seen.add(en.target);
                    var idx = Array.prototype.indexOf.call(bars, en.target);
                    setTimeout(
                        function () {
                            en.target.style.width = en.target.dataset.w;
                        },
                        150 + (idx % 6) * 70,
                    );
                }
            });
        });
        bars.forEach(function (b) {
            io.observe(b);
        });
    })();

    // ─────────── Control tamaño de fuente (flotante) ───────────
    (function () {
        var sizes = ["", "lg", "xl"];
        var current = localStorage.getItem("textSize") || "";
        var panel = document.getElementById("fsPanel");
        var floatBtn = document.getElementById("fsFloatBtn");
        var btnSm = document.getElementById("fsSm");
        var btnLg = document.getElementById("fsLg");
        var btnXl = document.getElementById("fsXl");
        function apply(size) {
            current = size;
            // Aplica al root (html) para escalar todas las medidas en 'rem' correctamente
            document.documentElement.style.fontSize =
                size === "lg" ? "110%" : size === "xl" ? "125%" : "";
            localStorage.setItem("textSize", size);
            [btnSm, btnLg, btnXl].forEach(function (b) {
                b && b.classList.remove("on");
            });
            if (size === "") btnSm && btnSm.classList.add("on");
            if (size === "lg") btnLg && btnLg.classList.add("on");
            if (size === "xl") btnXl && btnXl.classList.add("on");
        }
        function togglePanel() {
            var open = !panel.hidden;
            panel.hidden = open;
            floatBtn.setAttribute("aria-expanded", String(!open));
        }
        apply(current);
        floatBtn &&
            floatBtn.addEventListener("click", function (e) {
                e.stopPropagation();
                togglePanel();
            });
        btnSm &&
            btnSm.addEventListener("click", function () {
                apply("");
            });
        btnLg &&
            btnLg.addEventListener("click", function () {
                apply("lg");
            });
        btnXl &&
            btnXl.addEventListener("click", function () {
                apply("xl");
            });
        document.addEventListener("click", function (e) {
            var float = document.getElementById("fsFloat");
            if (float && !float.contains(e.target) && !panel.hidden)
                panel.hidden = true;
        });
    })();

    // ─────────── Botones de compartir ───────────
    (function () {
        var toast = document.getElementById("toast");
        function showToast(msg) {
            toast.textContent = msg;
            toast.classList.add("show");
            clearTimeout(toast._t);
            toast._t = setTimeout(function () {
                toast.classList.remove("show");
            }, 2200);
        }

        function getShareData() {
            var entityName = document.getElementById("genEntityName");
            var genMonto = document.getElementById("genMonto");
            var name = entityName
                ? entityName.textContent.trim()
                : "un proveedor";
            var amount = genMonto ? genMonto.textContent.trim() : "";
            return {
                title: "Datos Pauta Oficial",
                text:
                    name +
                    " recibió " +
                    amount +
                    " en pauta oficial · datospautaoficial.com.ar",
                url: "https://datospautaoficial.com.ar/?p=clarin&y=historico",
            };
        }

        var shareX = document.getElementById("shareX");
        var shareIG = document.getElementById("shareIG");
        var shareCopy = document.getElementById("shareCopy");

        if (shareX)
            shareX.addEventListener("click", function () {
                var d = getShareData();
                var tweetText = encodeURIComponent(d.text + "\n" + d.url);
                window.open(
                    "https://twitter.com/intent/tweet?text=" + tweetText,
                    "_blank",
                    "noopener",
                );
            });

        if (shareIG)
            shareIG.addEventListener("click", function () {
                if (navigator.share) {
                    navigator.share(getShareData()).catch(function () {});
                } else {
                    var d = getShareData();
                    navigator.clipboard
                        .writeText(d.url)
                        .then(function () {
                            showToast(
                                "Link copiado \u00b7 pegalo en Instagram",
                            );
                        })
                        .catch(function () {
                            showToast("Link: datospautaoficial.com.ar");
                        });
                }
            });

        if (shareCopy)
            shareCopy.addEventListener("click", function () {
                var url = getShareData().url;
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard
                        .writeText(url)
                        .then(function () {
                            showToast("Link copiado al portapapeles");
                        })
                        .catch(function () {
                            showToast("Link: " + url);
                        });
                } else {
                    showToast("Link: " + url);
                }
            });
    })();

    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Scroll hint (flotante hero) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    (function () {
        var hint = document.getElementById("scrollHint");
        if (!hint) return;
        hint.addEventListener("click", function () {
            var target = document.querySelector(".table-section");
            if (target) target.scrollIntoView({ behavior: "smooth" });
        });
        var hidden = false;
        window.addEventListener(
            "scroll",
            function () {
                var y = window.scrollY || window.pageYOffset;
                if (!hidden && y > 80) {
                    hint.classList.add("hidden");
                    hidden = true;
                } else if (hidden && y <= 80) {
                    hint.classList.remove("hidden");
                    hidden = false;
                }
            },
            { passive: true },
        );
    })();

    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Volver al inicio \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    (function () {
        var btn = document.getElementById("backTopBtn");
        if (!btn) return;
        window.addEventListener(
            "scroll",
            function () {
                var y = window.scrollY || window.pageYOffset;
                btn.style.display = y > 300 ? "" : "none";
            },
            { passive: true },
        );
        btn.addEventListener("click", function () {
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    })();

    // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Nav: link activo por scroll \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    (function () {
        var links = document.querySelectorAll(".nav-link[data-nav]");
        var sections = [];
        links.forEach(function (l) {
            var el = document.getElementById(l.dataset.nav);
            if (el) sections.push({ el: el, link: l });
        });
        if (!sections.length) return;
        var navH =
            (document.getElementById("site-nav") || {}).offsetHeight || 44;
        function update() {
            var y = window.scrollY || window.pageYOffset;
            var active = sections[0];
            for (var i = 0; i < sections.length; i++) {
                if (sections[i].el.getBoundingClientRect().top <= navH + 8) {
                    active = sections[i];
                }
            }
            links.forEach(function (l) {
                l.classList.remove("active");
            });
            active.link.classList.add("active");
        }
        window.addEventListener("scroll", update, { passive: true });
        update();
    })();

    // ─────────── Mobile Menu Toggle ───────────
    (function () {
        var btn = document.getElementById("mobileMenuBtn");
        var links = document.getElementById("navLinks");
        var nav = document.getElementById("site-nav");
        if (btn && links && nav) {
            btn.addEventListener("click", function () {
                var expanded = btn.getAttribute("aria-expanded") === "true";
                btn.setAttribute("aria-expanded", !expanded);
                links.classList.toggle("open");
            });
            links.addEventListener("click", function (e) {
                if (e.target.tagName.toLowerCase() === "a") {
                    btn.setAttribute("aria-expanded", "false");
                    links.classList.remove("open");
                }
            });
            document.addEventListener("click", function (e) {
                if (!nav.contains(e.target) && links.classList.contains("open")) {
                    btn.setAttribute("aria-expanded", "false");
                    links.classList.remove("open");
                }
            });
        }
    })();

    // ─────────── Smart Sticky Header ───────────
    (function() {
        var lastScroll = 0;
        var nav = document.getElementById("site-nav");
        if (!nav) return;
        window.addEventListener("scroll", function() {
            var currentScroll = window.pageYOffset;
            if (currentScroll <= 56) {
                nav.classList.remove("scroll-up");
                nav.classList.remove("scroll-down");
                return;
            }
            if (currentScroll > lastScroll && !nav.classList.contains("scroll-down")) {
                nav.classList.remove("scroll-up");
                nav.classList.add("scroll-down");
            } else if (currentScroll < lastScroll && nav.classList.contains("scroll-down")) {
                nav.classList.remove("scroll-down");
                nav.classList.add("scroll-up");
            }
            lastScroll = currentScroll;
        }, { passive: true });
    })();

    // ─────────── Mock Buscador (Visual Feedback & Empty State) ───────────
    (function() {
        var input = document.querySelector(".gen-search-input");
        var iconWrap = document.querySelector(".gen-search-input-wrap svg.search-icon");
        var result = document.querySelector(".gen-result");
        var empty = document.getElementById("genEmpty");
        if (!input || !iconWrap || !result || !empty) return;
        
        var originalSVG = iconWrap.innerHTML;
        var spinnerSVG = '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" stroke-dasharray="31.4 31.4" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/></circle>';
        
        input.addEventListener("keydown", function(e) {
            if (e.key === "Enter") {
                var val = input.value.trim().toLowerCase();
                
                // Loading state
                iconWrap.innerHTML = spinnerSVG;
                result.style.opacity = "0.3";
                empty.style.opacity = "0.3";
                
                setTimeout(function() {
                    iconWrap.innerHTML = originalSVG;
                    result.style.opacity = "1";
                    empty.style.opacity = "1";
                    
                    if (val === "vacio" || val === "nada" || val === "test") {
                        result.style.display = "none";
                        empty.style.display = "block";
                    } else {
                        result.style.display = "block";
                        empty.style.display = "none";
                    }
                }, 600);
            }
        });
    })();
</script>
