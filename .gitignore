# dependencias
node_modules/

# build de Astro
dist/
.astro/

# base de datos y artefactos generados — derivados de etl/data/*.csv via etl/build_db.py.
# No se versionan: son artefactos reproducibles, no fuentes.
public/data/*.sqlite
public/data/*.sqlite3
public/data/*.db
public/data/pauta.sqlite.*
public/data/config.json
public/data/search.json
# SQLite monolitica generada en etl/build/ (fuera de public/ para no superar
# el limite de 25 MiB de Cloudflare Pages; los chunks van a public/data/).
etl/build/

# Python (ETL)
__pycache__/
*.pyc
.venv/
venv/

# entornos y secretos
.env
.env.*
!.env.example

# logs y temporales del sistema
*.log
.DS_Store
Thumbs.db
